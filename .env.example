# Local dev database (Postgres running in this container)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# Stripe (TEST mode). Leave blank to use the dev simulated-payment fallback.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Email (Resend). Leave blank to log emails to the server console in dev.
RESEND_API_KEY=""
EMAIL_FROM="Whitetail Ridge Golf Dome <events@whitetailridgedome.com>"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
